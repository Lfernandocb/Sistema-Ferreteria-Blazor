@page "/inventario"
@using FerreteriaWeb.Data
@inject ProductoService ProductoService

<h3 class="mb-4">📦 Gestión de Inventario - Ferretería</h3>

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        @(editando ? "Editar Producto" : "Agregar Nuevo Producto")
    </div>

    <div class="card-body">
        <div class="row">

            <div class="col-md-4">
                <label>Nombre</label>
                <input class="form-control" @bind="productoActual.nombre" />
            </div>

            <div class="col-md-3">
                <label>Precio Venta</label>
                <input type="number" class="form-control" @bind="productoActual.precio_venta" />
            </div>

            <div class="col-md-3">
                <label>Stock / Material</label>
                <input type="number" class="form-control" @bind="productoActual.stock_real" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-success w-100" @onclick="GuardarProducto">
                    @(editando ? "Actualizar" : "Guardar")
                </button>
            </div>

        </div>

        @if (editando)
        {
            <button class="btn btn-secondary mt-3" @onclick="CancelarEdicion">
                Cancelar edición
            </button>
        }
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-8">
        <input class="form-control"
               placeholder="Buscar producto por nombre..."
               @bind="busqueda"
               @bind:event="oninput" />
    </div>

    <div class="col-md-4">
        <select class="form-control" @bind="registrosPorPagina">
            <option value="5">5 registros por página</option>
            <option value="10">10 registros por página</option>
            <option value="20">20 registros por página</option>
        </select>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Precio Venta</th>
            <th>Stock / Material</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var p in ProductosPaginados)
        {
            <tr>
                <td>@p.id_producto</td>
                <td>@p.nombre</td>
                <td>NIO @p.precio_venta.ToString("0.00")</td>
                <td>@p.stock_real</td>
                <td>
                    <button class="btn btn-warning btn-sm me-2" @onclick="() => EditarProducto(p)">
                        Editar
                    </button>

                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarProducto(p.id_producto)">
                        Eliminar
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div>
        Mostrando página @paginaActual de @TotalPaginas
    </div>

    <div>
        <button class="btn btn-secondary me-2"
                disabled="@(paginaActual == 1)"
                @onclick="PaginaAnterior">
            Anterior
        </button>

        <button class="btn btn-secondary"
                disabled="@(paginaActual == TotalPaginas)"
                @onclick="PaginaSiguiente">
            Siguiente
        </button>
    </div>
</div>

@code {
    private List<Producto> productos = new();
    private Producto productoActual = new();

    private string busqueda = "";
    private string mensaje = "";
    private bool editando = false;

    private int paginaActual = 1;
    private int registrosPorPagina = 5;

    private IEnumerable<Producto> ProductosFiltrados =>
        string.IsNullOrWhiteSpace(busqueda)
            ? productos
            : productos.Where(p => p.nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase));

    private int TotalRegistros => ProductosFiltrados.Count();

    private int TotalPaginas =>
        TotalRegistros == 0
            ? 1
            : (int)Math.Ceiling((double)TotalRegistros / registrosPorPagina);

    private IEnumerable<Producto> ProductosPaginados =>
        ProductosFiltrados
            .Skip((paginaActual - 1) * registrosPorPagina)
            .Take(registrosPorPagina);

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        productos = await ProductoService.GetProductosAsync();

        if (paginaActual > TotalPaginas)
        {
            paginaActual = TotalPaginas;
        }
    }

    private async Task GuardarProducto()
    {
        mensaje = "";

        if (string.IsNullOrWhiteSpace(productoActual.nombre))
        {
            mensaje = "Debe ingresar el nombre del producto.";
            return;
        }

        if (productoActual.precio_venta <= 0)
        {
            mensaje = "El precio debe ser mayor que cero.";
            return;
        }

        if (productoActual.stock_real < 0)
        {
            mensaje = "El stock/material no puede ser negativo.";
            return;
        }

        bool resultado;

        if (editando)
        {
            resultado = await ProductoService.ActualizarProductoAsync(productoActual);

            mensaje = resultado
                ? "Producto actualizado correctamente."
                : "No se pudo actualizar el producto: " + ProductoService.UltimoError;
        }
        else
        {
            resultado = await ProductoService.InsertarProductoAsync(productoActual);

            mensaje = resultado
                ? "Producto guardado correctamente."
                : "No se pudo guardar el producto: " + ProductoService.UltimoError;
        }

        productoActual = new Producto();
        editando = false;

        await CargarProductos();
    }

    private void EditarProducto(Producto producto)
    {
        productoActual = new Producto
        {
            id_producto = producto.id_producto,
            nombre = producto.nombre,
            precio_venta = producto.precio_venta,
            stock_real = producto.stock_real
        };

        editando = true;
    }

    private async Task EliminarProducto(int id)
    {
        var resultado = await ProductoService.EliminarProductoAsync(id);

        mensaje = resultado
            ? "Producto eliminado correctamente."
            : "No se pudo eliminar el producto: " + ProductoService.UltimoError;

        await CargarProductos();
    }

    private void CancelarEdicion()
    {
        productoActual = new Producto();
        editando = false;
        mensaje = "";
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
        {
            paginaActual--;
        }
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
        {
            paginaActual++;
        }
    }
}